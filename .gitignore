apps/*/android/build/
apps/*/android/app/build/
apps/*/android/.idea/
apps/*/android/local.properties
apps/*/android/**/*.keystore
!apps/*/android/app/debug.keystore

# Env & secrets — 1Password is the source of truth
.env
.env.*
!.env.tpl
!.env.*.tpl
*.pem
*.p12
*.p8
*.mobileprovision
*.jks

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Editors
.vscode/
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
.DS_Store

# Test / coverage
coverage/
.nyc_output/

# EAS
.eas/
