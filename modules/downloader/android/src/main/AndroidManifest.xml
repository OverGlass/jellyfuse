<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!--
    Permissions for background downloads:
    - INTERNET:                       HTTP fetch.
    - FOREGROUND_SERVICE:             long-running download worker.
    - FOREGROUND_SERVICE_DATA_SYNC:   API 34+ requires a typed flavor.
    - POST_NOTIFICATIONS:             API 33+ runtime permission to show progress notifications.
    - WAKE_LOCK:                      keep CPU awake during active download (WorkManager uses it internally).
  -->
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <!--
    The download foreground service will be declared in the app-merged
    manifest once Phase B ships DownloadForegroundService. For Phase A the
    Kotlin module is a stub so no <service> is registered.
  -->
</manifest>
