<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">

  <!--
    Permissions for background downloads:
    - INTERNET:                       HTTP fetch.
    - FOREGROUND_SERVICE:             long-running download worker.
    - FOREGROUND_SERVICE_DATA_SYNC:   API 34+ requires a typed flavor.
    - POST_NOTIFICATIONS:             API 33+ runtime permission to show progress notifications.
    - WAKE_LOCK:                      keep CPU awake during active download (WorkManager uses it internally).
  -->
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <application>
    <!--
      WorkManager runs all foreground CoroutineWorkers through its own
      `SystemForegroundService`. On API 34+ the service's manifest entry
      MUST declare a `foregroundServiceType` or `startForeground()` fails.
      We merge `dataSync` into WorkManager's manifest declaration so the
      download worker can promote itself via `setForeground(...)`.
    -->
    <service
      android:name="androidx.work.impl.foreground.SystemForegroundService"
      android:foregroundServiceType="dataSync"
      tools:node="merge" />
  </application>
</manifest>
