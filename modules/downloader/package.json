{
  "name": "@jellyfuse/downloader",
  "version": "0.0.0",
  "private": true,
  "description": "Background download manager Nitro module for Jellyfuse (iOS URLSession / Android WorkManager).",
  "files": [
    "src",
    "ios",
    "nitrogen",
    "plugin",
    "app.plugin.js",
    "nitro.json",
    "Downloader.podspec"
  ],
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "nitrogen": "nitrogen",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@jellyfuse/tsconfig-base": "workspace:*",
    "@typescript/native-preview": "^7.0.0-dev",
    "nitrogen": "^0.35.0",
    "react-native-nitro-modules": "^0.35.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.0 <1.0.0"
  }
}
