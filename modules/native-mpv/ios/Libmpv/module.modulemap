// Custom modulemap for MPVKit's libmpv static archive.
// The vendored .a files live under vendor/ios/mpvkit-{device,simulator}
// and the headers under vendor/ios/mpvkit-{device,simulator}/include/mpv/.
// The podspec's HEADER_SEARCH_PATHS resolves `mpv/client.h` etc.

module Libmpv [system] {
    header "mpv/client.h"
    header "mpv/render.h"
    header "mpv/render_gl.h"
    header "mpv/stream_cb.h"
    export *
}
