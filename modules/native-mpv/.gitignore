# Per-machine libmpv-apple symlinks created by scripts/fetch-libmpv.sh.
# They point at ~/Library/Caches/jellyfuse/libmpv-apple/$VERSION/, so the
# stored symlink target is user-specific and not portable. Each clone
# regenerates them via the fetch script (called from
# apps/mobile/eas-build-post-install.sh, or run manually before the
# first iOS build).
vendor/ios/libmpv-device
vendor/ios/libmpv-simulator
